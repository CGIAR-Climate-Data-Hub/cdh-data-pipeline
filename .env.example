# Copy to .env and fill in. Load it with:
#   uv run --env-file .env recipes/<name>.py      (or: export UV_ENV_FILE=.env)

# Harvard Dataverse API token — mapspam source downloads (recipes/mapspam.py fetch()).
# One-time: register at https://dataverse.harvard.edu, then account menu -> API Token.
DATAVERSE_TOKEN=

# AWS credentials: recipes whose OUTPUT is s3://.
# Obstore does not access ~/.aws/credentials so the alternative is to
# use aws configure export-credentials --profile default --format env | source
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
